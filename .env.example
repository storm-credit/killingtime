# Copy to .env and fill in only what you need.
# .env is gitignored.

# Vertex AI (default). Put your service account JSON at secrets/vertex-sa-key.json
# (gitignored) and docker-compose will mount it automatically.
# To override the host path, set VERTEX_SA_KEY_PATH to an absolute path.
VERTEX_SA_KEY_PATH=./secrets/vertex-sa-key.json

# Claude (engine=claude)
ANTHROPIC_API_KEY=

# Gemini API direct (engine=gemini)
GEMINI_API_KEY=

# GPT (engine=gpt)
OPENAI_API_KEY=
